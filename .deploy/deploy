#!/bin/bash
#
# Before run: chmod +x .deploy/deploy
# https://stackoverflow.com/questions/42154912/permission-denied-for-build-sh-file
#
# Usage (from project root):
#   ./.deploy/deploy stage      # dry run: show what would change
#   ./.deploy/deploy stage go   # deploy for real
#
# Sources:
# - https://github.com/HashandSalt/ForgeLiteKirby/blob/develop/config/deploy
# - https://forum.getkirby.com/t/deployment-techniques-and-tools/18144/4

set -euo pipefail

# Load project-specific config (gitignored). See config.example.
CONFIG="./.deploy/config"
if [[ ! -f "${CONFIG}" ]]; then
	echo -e "\033[31m! Error:\tMissing ${CONFIG}\033[0m"
	echo -e "\033[31m\tCopy .deploy/config.example to .deploy/config and fill it in.\033[0m"
	exit 1
fi
# shellcheck source=/dev/null
source "${CONFIG}"

# Get current folder
BASE=$(basename "${PWD}")

ERRORSTRING="Whoops! That didn't work. Please check the command you ran."

if [[ "${BASE}" == "${LOCAL}" ]]
then
	echo -e "\033[93m\xe2\x80\xa2 Project:\t${PROJECT}\033[0m"
	echo -e "\033[93m\xe2\x80\xa2 Local:\t$(pwd)\033[0m"
	echo -e "\033[93m\xe2\x80\xa2 Target:\t${TARGET}\033[0m"
	echo -e "\033[93m\xe2\x80\xa2 Server:\t\xe2\x86\xa6 ${SERVER}\033[0m"

	if [ $# -eq 0 ]
	then
		echo "$ERRORSTRING"
		exit 1

	elif [[ "$1" == "stage" ]]
	then
		if [[ -z "${2:-}" ]]
		then
			echo -e "\033[93m\xe2\x80\xa2 Action:\tCompare file tree (dry run)\033[0m"
			echo ""
			rsync --dry-run -avz --delete --progress \
				--exclude-from="./.deploy/rsync_exclude.txt" \
				-e "ssh ${PORT}" "${FOLDER}" "${SERVER}:${TARGET}" \
				&& echo -e "\033[92m\xe2\x9c\x93 Dry run completed\033[0m"
		elif [[ "$2" == "go" ]]
		then
			echo -e "\033[93m\xe2\x80\xa2 Action:\tDeploy on server\033[0m"
			echo ""
			rsync -avz --delete --progress \
				--exclude-from="./.deploy/rsync_exclude.txt" \
				-e "ssh ${PORT}" "${FOLDER}" "${SERVER}:${TARGET}" \
				&& echo -e "\033[92m\xe2\x9c\x93 Deployed on live server\033[0m"
		else
			echo "$ERRORSTRING"
			exit 1
		fi
	else
		echo "$ERRORSTRING"
		exit 1
	fi
else
	echo -e "\033[31m\xe2\x80\xa2 Project:\t${PROJECT}\033[0m"
	echo -e "\033[31m\xe2\x80\xa2 Local:\t$(pwd)\033[0m"
	echo -e "\033[31m\xe2\x80\xa2 Target:\t${TARGET}\033[0m"
	echo -e "\033[31m\xe2\x80\xa2 Server:\t\xe2\x86\xa6 ${SERVER}\033[0m"
	echo -e "\033[31m-----------------------------------------------------------------\033[0m"
	echo -e "\033[31m! Error:\tWrong folder name\033[0m"
	echo -e "\033[31m\xe2\x80\xa2 Expected:\t/${LOCAL}\033[0m"
	echo -e "\033[31m\xe2\x80\xa2 Current:\t/${BASE}\033[0m"
	echo -e "\033[31m-----------------------------------------------------------------\033[0m"
	exit 1
fi

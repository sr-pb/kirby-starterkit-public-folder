#!/bin/bash
#
# Before run: chmod +x .deploy/deploy
# https://stackoverflow.com/questions/42154912/permission-denied-for-build-sh-file
#
# Usage (from project root):
#   ./.deploy/deploy <profile>       # dry run: show what would change
#   ./.deploy/deploy <profile> go    # deploy for real
#
# Profiles are defined in .deploy/config (see config.example).
# Example: ./.deploy/deploy live      |  ./.deploy/deploy live go
#
# Sources:
# - https://github.com/HashandSalt/ForgeLiteKirby/blob/develop/config/deploy
# - https://forum.getkirby.com/t/deployment-techniques-and-tools/18144/4

set -euo pipefail

# --- Styling (only when writing to a terminal) ---------------------------
if [[ -t 1 ]]; then
	BOLD=$'\033[1m'; RESET=$'\033[0m'
	YELLOW=$'\033[93m'; GREEN=$'\033[92m'; RED=$'\033[91m'
else
	BOLD=""; RESET=""; YELLOW=""; GREEN=""; RED=""
fi
DOT="•"; OK="✓"; CROSS="✗"; WARN="⚠"
LINE="────────────────────────────────────────────────────────────"

# --- Config (gitignored; see config.example) -----------------------------
CONFIG="./.deploy/config"
if [[ ! -f "${CONFIG}" ]]; then
	printf '%s%s Error:%s  Missing %s\n' "${RED}" "${WARN}" "${RESET}" "${CONFIG}"
	printf '%s         Copy .deploy/config.example to .deploy/config and fill it in.%s\n' "${RED}" "${RESET}"
	exit 1
fi
# shellcheck source=/dev/null
source "${CONFIG}"

EXCLUDE="./.deploy/rsync_exclude.txt"
BASE=$(basename "${PWD}")
ERRORSTRING="Usage: ./.deploy/deploy <profile> [go]   (e.g. live | live go)"

# label  value  [color]
row() {
	local color="${3:-${YELLOW}}"
	printf '%s%s %-9s%s %s\n' "${color}" "${DOT}" "$1" "${RESET}" "$2"
}

fail() {
	printf '%s%s %s%s\n' "${RED}" "${CROSS}" "$1" "${RESET}"
	exit 1
}

# --- Folder guard ---------------------------------------------------------
if [[ "${BASE}" != "${LOCAL}" ]]; then
	printf '%s%s%s\n' "${RED}" "${LINE}" "${RESET}"
	printf '%s%s Wrong folder name%s\n' "${RED}" "${WARN}" "${RESET}"
	row "Expected" "/${LOCAL}" "${RED}"
	row "Current"  "/${BASE}"  "${RED}"
	printf '%s%s%s\n' "${RED}" "${LINE}" "${RESET}"
	exit 1
fi

# --- Resolve profile ------------------------------------------------------
PROFILE="${1:-}"
[[ -z "${PROFILE}" ]] && fail "${ERRORSTRING}"

MODE="${2:-}"
case "${MODE}" in
	"")   LIVE=0 ;;   # dry run
	go)   LIVE=1 ;;   # real
	*)    fail "${ERRORSTRING}" ;;
esac

# Pull profile fields by name (e.g. LIVE_SERVER)
KEY=$(echo "${PROFILE}" | tr '[:lower:]' '[:upper:]')
SERVER_VAR="${KEY}_SERVER"
TARGET_VAR="${KEY}_TARGET"
PORT_VAR="${KEY}_PORT"

if [[ -z "${!SERVER_VAR:-}" || -z "${!TARGET_VAR:-}" ]]; then
	fail "Unknown or incomplete profile: '${PROFILE}'. Check ${CONFIG}."
fi

SERVER="${!SERVER_VAR}"
TARGET="${!TARGET_VAR}"
# Per-profile port if set, otherwise the global PORT
SSH_PORT="${!PORT_VAR:-${PORT:-}}"

# --- Output header --------------------------------------------------------
row "Project" "${PROJECT}"
row "Profile" "${PROFILE}"
row "Source"  "${FOLDER}"
row "Target"  "${SERVER}:${TARGET}"

run_rsync() {
	local dry=""
	[[ "${LIVE}" -eq 0 ]] && dry="--dry-run"
	rsync ${dry} -azLK --force --delete --progress \
		--exclude-from="${EXCLUDE}" \
		-e "ssh ${SSH_PORT}" "${FOLDER}" "${SERVER}:${TARGET}"
}

if [[ "${LIVE}" -eq 0 ]]; then
	row "Action" "Dry run (no changes)"
	echo ""
	run_rsync
	printf '%s%s Dry run completed%s\n' "${GREEN}" "${OK}" "${RESET}"
else
	row "Action" "${BOLD}DEPLOY FOR REAL${RESET}"
	echo ""
	run_rsync
	printf '%s%s Deployed (%s)%s\n' "${GREEN}" "${OK}" "${PROFILE}" "${RESET}"
fi

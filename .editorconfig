root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,ts,vue}]
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
# Trailing whitespace is intentional in Markdown (two spaces = <br>)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[{package.json,composer.json,.babelrc}]
indent_size = 2
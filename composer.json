{
  "name": "sr/kirby-starterkit",
  "description": "SR Kirby starterkit public folder",
  "type": "project",
  "require": {
    "php": "~8.1.0 || ~8.2.0 || ~8.3.0",
    "getkirby/cms": "^5.0",
    "bnomei/kirby3-fingerprint": "^5.2",
    "afbora/kirby-minify-html": "^2.2"
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8000 kirby/router.php"
    ]
  }
}
